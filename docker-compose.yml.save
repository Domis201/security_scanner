services:
  db:
    image: mysql:8.0
    container_name: scanner_db
    environment:
      MYSQL_DATABASE: scanner_db
      MYSQL_USER: user
      MYSQL_PASSWORD: password123
      MYSQL_ROOT_PASSWORD: rootpassword
    volumes:
      - db_data:/var/lib/mysql

  redis:
    image: redis:alpine
    container_name: scanner_redis

  backend:
    build: ./backend
    container_name: scanner_backend
    volumes:
      - ./backend:/app
    ports:
      - "8000:8000"
    environment:
      - DB_HOST=db
      - REDIS_URL=redis://redis:6379/0
    depends_on:
      - db
      - redis

  worker:
    build: ./backend
    container_name: scanner_worker
    command: celery -A core worker --loglevel=info
    volumes:
      - ./backend:/app
    environment:
      - DB_HOST=db
      - REDIS_URL=redis://redis:6379/0
    depends_on:
      - db
      - redis
   zap:
        image: owasp/zap2docker-stable
        container_name: scanner_zap
        command: zap.sh -daemon -host 0.0.0.0 -port 8080 -config api.disablekey=true -config api.addrs.addr.name=.* -config api.addrs.addr.mask=.*
        ports:
          - "8081:8080"

volumes:
  db_data:
